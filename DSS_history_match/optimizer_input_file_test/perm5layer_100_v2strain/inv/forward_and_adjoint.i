[DiracKernels]
  # Dipole adjoint source: two point sources per receiver shifted by +/- h/2 in
  # y, with amplitudes +/- m/h. Together they approximate d(delta)/dy, which is
  # the correct adjoint source for a strain_yy = d(disp_y)/dy objective.
  [misfit_upper]
    type = ReporterTimePointSource
    variable = 'disp_y_adjoint'
    value_name = 'misfit_up/values'
    x_coord_name = 'data/measurement_xcoord'
    y_coord_name = 'y_up/values'
    z_coord_name = 'data/measurement_zcoord'
    time_name = 'data/measurement_time'
