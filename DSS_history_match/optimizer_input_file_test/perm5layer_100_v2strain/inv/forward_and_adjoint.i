[Reporters]
  [data]
    type = OptimizationData
    objective_name = 'objective_value'
    # Forward objective is computed against the strain_yy aux variable
    # (sampled at fiber receiver points). The CSV measurement_values column
    # holds strain_yy ground truth produced by 102_observation_extractor.py.
    variable = 'strain_yy'
    outputs = 'none'
  []
  # --- Dipole adjoint source for a strain_yy objective -----------------------
  # J = 0.5 (strain_yy - meas)^2, strain_yy = d(disp_y)/dy, so the correct
  # adjoint source for disp_y_adjoint is a derivative-of-delta: a dipole.
  # We approximate it by two point sources shifted by +/- h_fd/2 in y with
  # amplitudes +/- m/h_fd, where m = sim - meas (already in data/misfit_values).
  # h_fd = 0.5 matches one mesh element in y (200 elements across 100 m).
  [y_up]
    type = ParsedVectorReporter
    name = values
    vector_reporter_names = 'data/measurement_ycoord'
    vector_reporter_symbols = 'y'
    expression = 'y + 0.25'
    outputs = 'none'
  []
  [y_down]
    type = ParsedVectorReporter
    name = values
    vector_reporter_names = 'data/measurement_ycoord'
    vector_reporter_symbols = 'y'
    expression = 'y - 0.25'
    outputs = 'none'
  []
  [misfit_up]
    type = ParsedVectorReporter
    name = values
    vector_reporter_names = 'data/misfit_values'
    vector_reporter_symbols = 'm'
    expression = 'm / 0.5'
    outputs = 'none'
  []
  [misfit_down]
    type = ParsedVectorReporter
    name = values
    vector_reporter_names = 'data/misfit_values'
    vector_reporter_symbols = 'm'
    expression = '-m / 0.5'
    outputs = 'none'
  []
