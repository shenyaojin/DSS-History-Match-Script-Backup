[Reporters]
  [main]
    type = OptimizationData
    # Path is relative to MOOSE's cwd. The MooseRunner stages this file into
    # inv_output/, so we go up one level to reach inv/measurement_data.csv.
    measurement_file = '../measurement_data.csv'
    file_xcoord = 'measurement_xcoord'
    file_ycoord = 'measurement_ycoord'
    file_zcoord = 'measurement_zcoord'
    file_time = 'measurement_time'
    file_value = 'measurement_values'
  []
[]

[MultiApps]
  [forward]
    type = FullSolveMultiApp
    # Same rationale as above: forward_and_adjoint.i lives in inv/, but MOOSE
    # runs from inv/inv_output/.
    input_files = '../forward_and_adjoint.i'
    execute_on = 'FORWARD'
  []
[]

