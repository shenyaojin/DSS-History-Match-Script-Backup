[Executioner]
  type = Optimize
  tao_solver = taoblmvm
  petsc_options_iname = '-tao_gatol'
  petsc_options_value = '0.0001'
  verbose = true
[]

[MultiApps]
  [forward]
    type = FullSolveMultiApp
    input_files = forward.i
    execute_on = "FORWARD"
    clone_parent_mesh = true
  []
  [adjoint]
    type = FullSolveMultiApp
    input_files = adjoint.i
    execute_on = "ADJOINT"
    clone_parent_mesh = true
  []
[]

[Transfers]
    [toForward]
        type = MultiAppReporterTransfer
        to_multi_app = forward
        from_reporters = 'main/measurement_xcoord
                          main/measurement_ycoord
                          main/measurement_zcoord
                          main/measurement_time
                          main/measurement_values
                          OptimizationReporter/perm_1
                          OptimizationReporter/perm_2
                          OptimizationReporter/perm_3'
        to_reporters = 'measure_data/measurement_xcoord
                        measure_data/measurement_ycoord
                        measure_data/measurement_zcoord
                        measure_data/measurement_time
                        measure_data/measurement_values
                        params/perm_1
                        params/perm_2
                        params/perm_3'
    []

    [fromForward_mesh]
        type = MultiAppCopyTransfer
        from_multi_app = forward
        to_multi_app = adjoint
        source_variable = 'disp_y'
        variable = 'disp_y_forward'
    []

    [fromForward]
        type = MultiAppReporterTransfer
        from_multi_app = forward
        from_reporters = 'measure_data/misfit_values measure_data/objective_value'
        to_reporters = 'main/misfit_values OptimizationReporter/objective_value'
    []

    [toAdjoint]
        type = MultiAppReporterTransfer
        to_multi_app = adjoint
        from_reporters = 'main/measurement_xcoord
                      main/measurement_ycoord
                      main/measurement_zcoord
                      main/measurement_time
                      main/misfit_values
                      OptimizationReporter/perm_1
                      OptimizationReporter/perm_2
                      OptimizationReporter/perm_3'
        to_reporters = 'misfit/measurement_xcoord
                    misfit/measurement_ycoord
                    misfit/measurement_zcoord
                    misfit/measurement_time
                    misfit/misfit_values
                    params/perm_1
                    params/perm_2
                    params/perm_3'
    []

    [fromAdjoint]
        type = MultiAppReporterTransfer
        from_multi_app = adjoint
        from_reporters = 'adjoint_grad/inner_product'
        to_reporters = 'OptimizationReporter/grad_perm_1
                        OptimizationReporter/grad_perm_2
                        OptimizationReporter/grad_perm_3'
    []
[]

[Output]
    csv = true
[]
